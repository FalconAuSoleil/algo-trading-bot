# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# Paper trading initial balance (USDC)
PAPER_INITIAL_BALANCE=10000

# Polymarket API (required for live trading only)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_PRIVATE_KEY=

# ═══════════════════════════════════════════════════════
# MICROSTRUCTURE STRATEGY PARAMETERS
# ═══════════════════════════════════════════════════════

# Signal thresholds
EDGE_MIN=0.08
MIN_TRUE_PROB=0.58
MAX_BET_FRACTION=0.04
MIN_MARKET_PROB_SIDE=0.20
MAX_MARKET_PROB_SIDE=0.80
MIN_MARKET_LIQUIDITY=15.0

# Timing — 5 minute markets
TIME_MIN_5M=45
TIME_MAX_5M=270
TIME_MAX_5M_ACCUM=400

# Timing — 15 minute markets
TIME_MIN_15M=60
TIME_MAX_15M=850

# Chainlink lag arbitrage
CHAINLINK_PERIOD=27.0
CHAINLINK_EDGE_WINDOW=8.0

# Order Flow Imbalance (OFI)
OFI_WEIGHT=0.30

# Kyle Lambda (price impact)
KYLE_SPREAD_PENALTY=0.15

# Hawkes Process (event clustering)
HAWKES_MU=0.1
HAWKES_ALPHA=0.8
HAWKES_BETA=2.0
HAWKES_HISTORY=200

# Momentum
MOMENTUM_FACTOR=150.0

# Stability filter
STABILITY_WINDOW_SEC=60.0
STABILITY_MIN_SAMPLES=3
STABILITY_MIN_RATIO=0.65
STABILITY_EDGE_CV_MAX=0.80

# ═══════════════════════════════════════════════════════
# RISK MANAGEMENT
# ═══════════════════════════════════════════════════════

KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.12
MAX_DAILY_DRAWDOWN=0.15
MAX_CONSECUTIVE_LOSSES=3
MAX_OPEN_POSITIONS=3
MAX_DAILY_RISK=0.25

# Dashboard
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0

# Database
DB_PATH=data/trades.db

# Logging
LOG_LEVEL=INFO
