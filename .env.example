# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# Paper trading initial balance (USDC)
PAPER_INITIAL_BALANCE=10000

# Polymarket API (required for live trading only)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_WALLET_ADDRESS=
POLYMARKET_PRIVATE_KEY=

# Signal Parameters
DELTA_MIN=0.0012
EDGE_MIN=0.08
TIME_MIN_SECONDS=15
TIME_MAX_SECONDS=120
VOLATILITY_MAX=0.0015
SOURCE_COHERENCE_MAX=0.0008

# Risk Parameters
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.12
MAX_DAILY_DRAWDOWN=0.15
MAX_CONSECUTIVE_LOSSES=3
MAX_OPEN_POSITIONS=3
MAX_DAILY_RISK=0.25

# Dashboard
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0

# Database
DB_PATH=data/trades.db

# Logging
LOG_LEVEL=INFO
